# Copy this file to .env.local and fill in real values (.env.local is git-ignored).
# Every VITE_* variable is PUBLIC: it is embedded into the built JavaScript and
# visible in the browser. Use only a public, referrer-restricted API key and a
# public Calendar ID here. NEVER put OAuth client secrets, refresh tokens or
# service-account JSON in this project.

# Public Google API key — restrict it in Google Cloud Console:
#   - Application restrictions: HTTP referrers (your GitHub Pages / custom domain)
#   - API restrictions: Google Calendar API only
VITE_GOOGLE_API_KEY=

# Public Google Calendar ID (Calendar settings → "Integrar agenda" → ID da agenda)
# e.g. abc123def456@group.calendar.google.com  (or an @gmail.com address)
VITE_GOOGLE_CALENDAR_ID=

# IANA timezone used to display event times
VITE_GOOGLE_TIMEZONE=America/Sao_Paulo
